        "sshAuthorizedKeys": [
          "##Authorized-Keys##"
        ]
      },
      {
        "name": "qevirt",
        "passwordHash": "$2a$10$v32/h9hPd9cATZgLI/a1AepB9eQuMbjvNBOxQIla19fmAMjznSczG",
        "sshAuthorizedKeys": [
          "##Authorized-Keys##"
        ]
      }
