From afdad18aa475989963a3bfcac566dc7436c241a6 Mon Sep 17 00:00:00 2001
From: Ricardo Branco <rbranco@suse.de>
Date: Sun, 22 Mar 2026 18:12:12 +0100
Subject: [PATCH 1/3] testutil/daemon: fix CgroupNamespace reading wrong
 process's ns

In rootless mode, d.Pid() returns the PID of the outermost process
started by the test framework (e.g., sudo), not dockerd itself.
Even without sudo, reading the shell's cgroup namespace instead of
dockerd's is incorrect.

dockerd always writes its own PID to the --pidfile passed by the test
framework, so read that instead. This gives the actual dockerd PID.

Signed-off-by: Ricardo Branco <rbranco@suse.de>
---
 internal/testutil/daemon/daemon_linux.go | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/internal/testutil/daemon/daemon_linux.go b/internal/testutil/daemon/daemon_linux.go
index 70a4fa15882b4..c9199af80e3a0 100644
--- a/internal/testutil/daemon/daemon_linux.go
+++ b/internal/testutil/daemon/daemon_linux.go
@@ -30,7 +30,10 @@ func cleanupNetworkNamespace(t testing.TB, d *Daemon) {
 
 // CgroupNamespace returns the cgroup namespace the daemon is running in
 func (d *Daemon) CgroupNamespace(t testing.TB) string {
-	link, err := os.Readlink(fmt.Sprintf("/proc/%d/ns/cgroup", d.Pid()))
+	pidBytes, err := os.ReadFile(d.pidFile)
+	assert.NilError(t, err)
+
+	link, err := os.Readlink(fmt.Sprintf("/proc/%s/ns/cgroup", strings.TrimSpace(string(pidBytes))))
 	assert.NilError(t, err)
 
 	return strings.TrimSpace(link)

From b3dbff82cc9f9448233ab50a31d3432b3a11ed88 Mon Sep 17 00:00:00 2001
From: Ricardo Branco <rbranco@suse.de>
Date: Sun, 22 Mar 2026 21:27:28 +0100
Subject: [PATCH 2/3] testutil/daemon: Set rootlesskit --state-dir on rootless
 tests

This is done to avoid colliding with another instance set up via
dockerd-rootless.sh

Signed-off-by: Ricardo Branco <rbranco@suse.de>
---
 internal/testutil/daemon/daemon.go | 1 +
 1 file changed, 1 insertion(+)

diff --git a/internal/testutil/daemon/daemon.go b/internal/testutil/daemon/daemon.go
index 2f55ddd11b645..d92278d987442 100644
--- a/internal/testutil/daemon/daemon.go
+++ b/internal/testutil/daemon/daemon.go
@@ -474,6 +474,7 @@ func (d *Daemon) StartWithLogFile(out *os.File, providedArgs ...string) error {
 			"--preserve-env=PATH", // Pass through PATH, overriding secure_path.
 			"XDG_RUNTIME_DIR="+d.rootlessXDGRuntimeDir,
 			"HOME="+d.rootlessUser.HomeDir,
+			"DOCKERD_ROOTLESS_ROOTLESSKIT_STATE_DIR="+filepath.Join(d.rootlessXDGRuntimeDir, "rootless"),
 			"--",
 			defaultDockerdRootlessBinary,
 		)

From a4c00cf6fa3bc830ef2b4477f6c2eeb076ce9bf8 Mon Sep 17 00:00:00 2001
From: Ricardo Branco <rbranco@suse.de>
Date: Sun, 22 Mar 2026 22:53:17 +0100
Subject: [PATCH 3/3] integration: Skip some tests when not run as root

These tests pass when DOCKER_ROOTLESS is set when run on privileged
containers but fail otherwise as they call mknod on /dev/, or try to
read /proc/1/ns/pid, etc.

Signed-off-by: Ricardo Branco <rbranco@suse.de>
---
 integration/container/mounts_linux_test.go  | 2 ++
 integration/container/pidmode_linux_test.go | 1 +
 integration/container/run_linux_test.go     | 2 ++
 3 files changed, 5 insertions(+)

diff --git a/integration/container/mounts_linux_test.go b/integration/container/mounts_linux_test.go
index b01a80ff447b9..73b97a288a606 100644
--- a/integration/container/mounts_linux_test.go
+++ b/integration/container/mounts_linux_test.go
@@ -74,6 +74,7 @@ func TestContainerMultipleMountsSamePath(t *testing.T) {
 func TestContainerNetworkMountsNoChown(t *testing.T) {
 	// chown only applies to Linux bind mounted volumes; must be same host to verify
 	skip.If(t, testEnv.IsRemoteDaemon)
+	skip.If(t, os.Getuid() != 0, "skipping test that requires root")
 
 	ctx := setupTest(t)
 
@@ -603,6 +604,7 @@ func TestContainerBindMountReadOnlyDefault(t *testing.T) {
 func TestContainerBindMountRecursivelyReadOnly(t *testing.T) {
 	skip.If(t, testEnv.IsRemoteDaemon)
 	skip.If(t, versions.LessThan(testEnv.DaemonAPIVersion(), "1.44"), "requires API v1.44")
+	skip.If(t, os.Getuid() != 0, "skipping test that requires root")
 
 	ctx := setupTest(t)
 
diff --git a/integration/container/pidmode_linux_test.go b/integration/container/pidmode_linux_test.go
index 9d1a8a54cb2da..11982f52a9225 100644
--- a/integration/container/pidmode_linux_test.go
+++ b/integration/container/pidmode_linux_test.go
@@ -15,6 +15,7 @@ import (
 func TestPIDModeHost(t *testing.T) {
 	skip.If(t, testEnv.DaemonInfo.OSType != "linux")
 	skip.If(t, testEnv.IsRemoteDaemon())
+	skip.If(t, os.Getuid() != 0, "skipping test that requires root")
 
 	hostPid, err := os.Readlink("/proc/1/ns/pid")
 	assert.NilError(t, err)
diff --git a/integration/container/run_linux_test.go b/integration/container/run_linux_test.go
index 1b5f53aa43cab..00255941b2608 100644
--- a/integration/container/run_linux_test.go
+++ b/integration/container/run_linux_test.go
@@ -134,6 +134,7 @@ func TestPrivilegedHostDevices(t *testing.T) {
 	// so needs to be same host.
 	skip.If(t, testEnv.IsRemoteDaemon)
 	skip.If(t, testEnv.DaemonInfo.OSType != "linux")
+	skip.If(t, os.Getuid() != 0, "skipping test that requires root")
 
 	ctx := setupTest(t)
 	apiClient := testEnv.APIClient()
@@ -207,6 +208,7 @@ func TestRunConsoleSize(t *testing.T) {
 func TestRunWithAlternativeContainerdShim(t *testing.T) {
 	skip.If(t, testEnv.IsRemoteDaemon)
 	skip.If(t, testEnv.DaemonInfo.OSType != "linux")
+	skip.If(t, os.Getuid() != 0, "skipping test that requires root")
 
 	ctx := testutil.StartSpan(baseContext, t)
 
