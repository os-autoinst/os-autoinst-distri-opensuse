From 331c046d510ade3ca090e161871470120499150b Mon Sep 17 00:00:00 2001
From: Ricardo Branco <rbranco@suse.de>
Date: Sat, 28 Feb 2026 19:03:45 +0100
Subject: [PATCH 1/3] tests: Adapt test to work on systems with 64k page size

Signed-off-by: Ricardo Branco <rbranco@suse.de>
---
 tests/containers_conf.bats | 9 ++++++++-
 1 file changed, 8 insertions(+), 1 deletion(-)

diff --git a/tests/containers_conf.bats b/tests/containers_conf.bats
index 802325b7233..1e8e16dffa4 100644
--- a/tests/containers_conf.bats
+++ b/tests/containers_conf.bats
@@ -83,7 +83,14 @@ load helpers
     run_buildah from --quiet $WITH_POLICY_JSON alpine
     cid="$output"
     run_buildah --log-level=error run $cid sh -c 'df /dev/shm | awk '\''/shm/{print $4}'\'''
-    expect_output "200"
+    # On architectures with 64k page size (e.g. ppc64le), the
+    # kernel rounds shm sizes up to the nearest page boundary.
+    pagesize="$(getconf PAGESIZE)"
+    expected=200
+    if [ "$pagesize" -eq 65536 ]; then
+        expected=256
+    fi
+    expect_output "$expected"
 }
 
 @test "containers.conf custom runtime" {

From 4a66ea9ee5d0b5c39a5827fb77c267788972fcd9 Mon Sep 17 00:00:00 2001
From: Ricardo Branco <rbranco@suse.de>
Date: Tue, 3 Mar 2026 00:14:08 +0100
Subject: [PATCH 2/3] tests: Fix tests to run on other architectures

Capture the container ID via --cidfile to avoid unexpected platform
warnings in output.

Also fix quoting issues and the expected architecture instead of
relying on the output of `go env GOARCH`.

Signed-off-by: Ricardo Branco <rbranco@suse.de>
---
