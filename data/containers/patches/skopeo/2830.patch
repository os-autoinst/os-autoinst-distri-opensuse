From c2372d9babb920dc5ab101781a27c7d15bccd5b5 Mon Sep 17 00:00:00 2001
From: Ricardo Branco <rbranco@suse.de>
Date: Sat, 21 Mar 2026 11:47:03 +0100
Subject: [PATCH] integration: Skip TestProxyMetadata on non-amd64
 architectures

https://github.com/containers/skopeo/issues/2829

Signed-off-by: Ricardo Branco <rbranco@suse.de>
---
 integration/proxy_test.go | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/integration/proxy_test.go b/integration/proxy_test.go
index 586035e6df..cc2815606d 100644
--- a/integration/proxy_test.go
+++ b/integration/proxy_test.go
@@ -9,6 +9,7 @@ import (
 	"net"
 	"os"
 	"os/exec"
+	"runtime"
 	"strings"
 	"sync"
 	"syscall"
@@ -478,6 +479,11 @@ func (s *proxySuite) TestProxyMetadata() {
 	p, err := newProxy()
 	require.NoError(t, err)
 
+	// https://github.com/containers/skopeo/issues/2829
+	if runtime.GOARCH != "amd64" {
+		t.Skip("test image is only available on amd64")
+	}
+
 	err = runTestMetadataAPIs(p, knownNotManifestListedImageX8664)
 	if err != nil {
 		err = fmt.Errorf("Testing image %s: %v", knownNotManifestListedImageX8664, err)
